#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 2 ]]; then
  echo "usage: $0 PR_NUMBER TARGET_BRANCH" >&2
  exit 1
fi

pr_number="$1"
target_branch="$2"

: "${GITHUB_OUTPUT:?GITHUB_OUTPUT is not set}"
: "${GH_TOKEN:?GH_TOKEN is not set}"

git config user.name 'github-actions[bot]'
git config user.email '41898282+github-actions[bot]@users.noreply.github.com'

merged=$(gh pr view "${pr_number}" --json merged -q .merged)
if [[ "${merged}" != "true" ]]; then
  echo "PR #${pr_number} is not merged; refusing to backport" >&2
  exit 1
fi

meta=$(gh pr view "${pr_number}" \
  --json title,mergeCommit,author \
  -q '{title,sha:.mergeCommit.oid,login:.author.login}')
title=$(jq -r '.title' <<<"${meta}")
sha=$(jq -r '.sha' <<<"${meta}")
login=$(jq -r '.login' <<<"${meta}")

if [[ -z "${sha}" || "${sha}" == "null" ]]; then
  echo "Could not determine merge commit SHA for PR #${pr_number}" >&2
  exit 1
fi

echo "backporting PR #${pr_number} (${sha}) by @${login} to ${target_branch}"

git fetch origin "${target_branch}"

branch="backport-${pr_number}-to-${target_branch}"
git checkout -b "${branch}" "origin/${target_branch}"

parent_count=$(git rev-list --parents -n 1 "${sha}" | wc -w)
if (( parent_count > 2 )); then
  cherry_args=(-x -m 1)
else
  cherry_args=(-x)
fi

cherry_status=0
git cherry-pick "${cherry_args[@]}" "${sha}" || cherry_status=$?

if [[ "${cherry_status}" -ne 0 ]]; then
  mapfile -t conflicted < <(git diff --name-only --diff-filter=U)

  if [[ ${#conflicted[@]} -eq 0 ]]; then
    echo "cherry-pick failed (status ${cherry_status}) with no conflicted paths" >&2
    exit 1
  fi

  git add -- "${conflicted[@]}"

  commit_msg=$(
    cat <<EOF
backport: cherry-pick #${pr_number} to ${target_branch}

Cherry-picked from commit ${sha}.
Conflict markers committed for follow-up resolution.
EOF
  )
  git commit -m "${commit_msg}"
fi

git push -u origin "${branch}"

pr_url=$(gh pr create \
  --base "${target_branch}" \
  --head "${branch}" \
  --draft \
  --title "[Backport ${target_branch}] ${title}" \
  --body "Backport of #${pr_number} to \`${target_branch}\`.")

pr_number_new="${pr_url##*/}"

if [[ -z "${pr_number_new}" || ! "${pr_number_new}" =~ ^[0-9]+$ ]]; then
  echo "Could not parse new PR number from gh output: ${pr_url}" >&2
  exit 1
fi

echo "created_pull_numbers=${pr_number_new}" >>"${GITHUB_OUTPUT}"
