#!/usr/bin/env python3
r"""Write and aggregate per-run nextest failure stats.

Requires the `gh` CLI on PATH, authenticated (GH_TOKEN or `gh auth login`).

Each main run writes a single-run JSON artifact. PR runs aggregate up to
--max-runs most recent main artifacts into a runs array for annotation.

Examples:
    # On main: export current run's failed/flaky lists.
    scripts/nextest-history write \
        --junit-dir junit-artifacts \
        --sha "$GITHUB_SHA" \
        --run-id "$GITHUB_RUN_ID" \
        --run-url "$GITHUB_SERVER_URL/$GITHUB_REPOSITORY/actions/runs/$GITHUB_RUN_ID" \
        --timestamp "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        --out test-stats.json

    # On a PR: pull and aggregate the last 20 main-branch stats artifacts.
    scripts/nextest-history fetch \
        --workflow test.yml \
        --artifact-name test-stats-test \
        --out main-test-stats.json

    # Debug a fetch that appears to do nothing:
    scripts/nextest-history --log-level debug fetch \
        --workflow test.yml --artifact-name test-stats-test --out /tmp/foo.json
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

import argparse
import json
import logging
import os
import subprocess
import tempfile
from typing import Any

from _nextest_parse import parse_junit_dir

log = logging.getLogger("nextest-history")


def write_empty(out: Path) -> None:
    out.write_text(json.dumps({"runs": []}))


def gh_json(args: list[str]) -> Any:
    cmd = ["gh", *args]
    try:
        result = subprocess.run(cmd, check=True, capture_output=True, text=True)
    except subprocess.CalledProcessError as e:
        raise RuntimeError(
            f"`{' '.join(cmd)}` exited {e.returncode}: {(e.stderr or '').strip()}"
        ) from e
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError as e:
        stdout = result.stdout.strip() or "<empty>"
        raise RuntimeError(
            f"`{' '.join(cmd)}` returned non-JSON output: {stdout[:200]} ({e})"
        ) from e


def resolve_repo() -> str:
    env_repo = os.environ.get("GITHUB_REPOSITORY")
    if env_repo:
        return env_repo
    cmd = ["gh", "repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner"]
    try:
        result = subprocess.run(cmd, check=True, capture_output=True, text=True)
    except subprocess.CalledProcessError as e:
        raise RuntimeError(
            f"`{' '.join(cmd)}` exited {e.returncode}: {(e.stderr or '').strip()}"
        ) from e
    repo = result.stdout.strip()
    if not repo:
        raise RuntimeError(f"`{' '.join(cmd)}` returned empty output")
    return repo


def download_artifact(repo: str, run_id: Any, artifact_name: str) -> dict | None:
    with tempfile.TemporaryDirectory(
        dir="./tmp" if Path("./tmp").exists() else None
    ) as td:
        subprocess.run(
            [
                "gh",
                "run",
                "download",
                str(run_id),
                "--repo",
                repo,
                "--name",
                artifact_name,
                "--dir",
                td,
            ],
            check=True,
            capture_output=True,
            text=True,
        )
        json_files = sorted(Path(td).rglob("*.json"))
        if not json_files:
            log.warning(
                "artifact %s from run %s had no JSON files", artifact_name, run_id
            )
            return None
        return json.loads(json_files[0].read_text())


def cmd_fetch(args: argparse.Namespace) -> int:
    try:
        repo = resolve_repo()
        log.info(
            "fetching up to %d %s artifacts from main runs of %s in %s",
            args.max_runs,
            args.artifact_name,
            args.workflow,
            repo,
        )
        runs_data = gh_json(
            [
                "api",
                "-X",
                "GET",
                f"repos/{repo}/actions/workflows/{args.workflow}/runs",
                "-F",
                "branch=main",
                "-F",
                "event=push",
                "-F",
                "status=success",
                "-F",
                f"per_page={args.max_runs}",
            ]
        )
        if not isinstance(runs_data, dict):
            raise RuntimeError(f"unexpected runs response: {runs_data!r}")
        workflow_runs = runs_data.get("workflow_runs", [])
        # Defend against GitHub not guaranteeing newest-first ordering.
        workflow_runs.sort(key=lambda r: r.get("created_at", ""), reverse=True)
        log.info("found %d successful main runs", len(workflow_runs))

        aggregated: list[dict] = []
        for run in workflow_runs:
            run_id = run["id"]
            try:
                artifacts_data = gh_json(
                    ["api", f"repos/{repo}/actions/runs/{run_id}/artifacts"]
                )
                artifacts = (
                    artifacts_data.get("artifacts", [])
                    if isinstance(artifacts_data, dict)
                    else []
                )
                match = next(
                    (
                        a
                        for a in artifacts
                        if a.get("name") == args.artifact_name
                        and not a.get("expired", False)
                    ),
                    None,
                )
                if match is None:
                    log.debug("run %s has no matching artifact", run_id)
                    continue
                entry = download_artifact(repo, run_id, args.artifact_name)
                if entry is None:
                    continue
                aggregated.append(entry)
            except (
                subprocess.CalledProcessError,
                json.JSONDecodeError,
                RuntimeError,
                OSError,
            ) as e:
                log.warning("run %s: skipping (%s)", run_id, e)
                continue

        args.out.write_text(
            json.dumps({"runs": aggregated}, indent=2, sort_keys=False) + "\n"
        )
        log.info("wrote %s with %d run(s)", args.out, len(aggregated))
        return 0
    except (
        subprocess.CalledProcessError,
        json.JSONDecodeError,
        RuntimeError,
        OSError,
    ) as e:
        log.warning("fetch failed, continuing with empty history: %s", e, exc_info=True)
        write_empty(args.out)
        return 0


def cmd_write(args: argparse.Namespace) -> int:
    failed, flaky, total = parse_junit_dir(args.junit_dir)
    if total == 0:
        log.error("no JUnit testcases parsed; refusing to write stats")
        return 1
    entry = {
        "sha": args.sha,
        "timestamp": args.timestamp,
        "run_id": args.run_id,
        "run_url": args.run_url,
        "failed": failed,
        "flaky": flaky,
    }
    args.out.write_text(json.dumps(entry, indent=2, sort_keys=False) + "\n")
    log.info(
        "wrote %s: %d failed, %d flaky in current run",
        args.out,
        len(failed),
        len(flaky),
    )
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--log-level",
        default=os.environ.get("NEXTEST_HISTORY_LOG", "INFO"),
        type=str.upper,
        choices=["DEBUG", "INFO", "WARNING", "ERROR"],
    )
    sub = parser.add_subparsers(dest="command", required=True)

    fetch = sub.add_parser(
        "fetch", help="aggregate recent main stats artifacts into a runs list"
    )
    fetch.add_argument("--workflow", required=True)
    fetch.add_argument("--artifact-name", required=True)
    fetch.add_argument("--out", required=True, type=Path)
    fetch.add_argument(
        "--max-runs",
        type=int,
        default=20,
        help="max recent main runs to scan for the artifact (default: 20, max: 100)",
    )
    fetch.set_defaults(func=cmd_fetch)

    write = sub.add_parser("write", help="export current run's failed/flaky lists")
    write.add_argument("--junit-dir", required=True, type=Path)
    write.add_argument("--sha", required=True)
    write.add_argument("--run-id", required=True)
    write.add_argument("--run-url", required=True)
    write.add_argument("--timestamp", required=True)
    write.add_argument("--out", required=True, type=Path)
    write.set_defaults(func=cmd_write)

    args = parser.parse_args()
    logging.basicConfig(
        level=args.log_level,
        format="%(levelname)s %(name)s: %(message)s",
        stream=sys.stderr,
    )
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
