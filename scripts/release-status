#!/usr/bin/env python3
"""Show current release status for the Espresso Network repo.

Displays floating Docker tags and where they point, recent YYYYMMDD git
tags with their Release/Pre-release classification and originating branch,
and active release branches with any tags not on main.

Requires `gh` authenticated (`gh auth login`).
"""

import argparse
import json
import re
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor
from datetime import datetime, timedelta, timezone

ORG = "espressosystems"
REPO = "espresso-network"
IMAGE = "ghcr.io/espressosystems/espresso-network/espresso-node"
FLOATING_TAGS = ["mainnet", "mainnet.canary", "decaf", "decaf.canary"]
PROMOTE_WORKFLOW = "promote-docker-tag.yml"

VERSION_TAG_RE = re.compile(r"^20\d{2}[01]\d[0-3]\d(\..+)?$")
ANY_DATE_TAG_RE = re.compile(r"^20\d{2}[01]\d[0-3]\d")


def run(cmd, check=True):
    return subprocess.run(cmd, check=check, capture_output=True, text=True)


def gh_json(path, paginate=True):
    cmd = ["gh", "api", path]
    if paginate:
        cmd.append("--paginate")
    try:
        result = run(cmd)
    except subprocess.CalledProcessError as e:
        stderr = (e.stderr or "").strip()
        print(f"error: gh api {path} failed: {stderr}", file=sys.stderr)
        if "HTTP 401" in stderr or "authentication" in stderr.lower():
            print("hint: run `gh auth login`", file=sys.stderr)
        sys.exit(1)
    text = result.stdout.strip()
    if not text:
        return []
    if paginate:
        try:
            return json.loads(text)
        except json.JSONDecodeError:
            return json.loads("[" + text.replace("][", ",") + "]")
    return json.loads(text)


def ago(delta):
    secs = max(int(delta.total_seconds()), 0)
    if secs < 3600:
        return f"{secs // 60}m ago"
    if secs < 86400:
        return f"{secs // 3600}h ago"
    days = secs // 86400
    if days < 365:
        return f"{days}d ago"
    return f"{days // 365}y ago"


def parse_ts(s):
    if s.endswith("Z"):
        s = s[:-1] + "+00:00"
    return datetime.fromisoformat(s).astimezone(timezone.utc)


def tag_digest(tag):
    try:
        result = run(["docker", "buildx", "imagetools", "inspect", "--raw", f"{IMAGE}:{tag}"], check=False)
    except FileNotFoundError:
        print("error: `docker` not found", file=sys.stderr)
        sys.exit(1)
    if result.returncode != 0:
        return None
    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError:
        return None
    for m in data.get("manifests", []):
        platform = m.get("platform", {})
        if platform.get("architecture") == "amd64" and platform.get("os") == "linux":
            return m.get("digest")
    return None


def fetch_promote_runs():
    data = gh_json(
        f"/repos/{ORG}/{REPO}/actions/workflows/{PROMOTE_WORKFLOW}/runs?per_page=100",
        paginate=True,
    )
    if isinstance(data, list):
        runs = []
        for chunk in data:
            runs.extend(chunk.get("workflow_runs", []))
        return runs
    return data.get("workflow_runs", []) if isinstance(data, dict) else []


def fetch_release_classification():
    data = gh_json(f"/repos/{ORG}/{REPO}/releases")
    out = {}
    for rel in data:
        tag = rel.get("tag_name")
        if tag:
            out[tag] = "Pre-release" if rel.get("prerelease") else "Release"
    return out


def git_tag_dates():
    result = run(
        ["git", "for-each-ref", "--format=%(refname:short) %(creatordate:iso-strict)", "refs/tags/20*"]
    )
    out = {}
    for line in result.stdout.splitlines():
        parts = line.split()
        if len(parts) >= 2:
            out[parts[0]] = parse_ts(parts[1])
    return out


def git_tags_merged_into(ref):
    result = run(["git", "tag", "--merged", ref])
    return set(result.stdout.split())


def git_release_branches():
    result = run(
        [
            "git",
            "for-each-ref",
            "--format=%(refname:short)\t%(objectname:short)\t%(authorname)\t%(authordate:iso-strict)",
            "refs/remotes/origin/release-*",
        ]
    )
    branches = []
    for line in result.stdout.splitlines():
        parts = line.split("\t")
        if len(parts) < 4:
            continue
        name, sha, author, date = parts
        branches.append((name.removeprefix("origin/"), sha, author, parse_ts(date)))
    return branches


def promote_run_for(runs, floating_tag, release_tag):
    matches = []
    for r in runs:
        if r.get("conclusion") != "success":
            continue
        title = r.get("display_title") or r.get("name") or ""
        if floating_tag in title and release_tag in title:
            matches.append(r)
    if not matches:
        return None
    return max(matches, key=lambda r: r["created_at"])


def floating_tag_targets(candidate_tags):
    all_tags = list(FLOATING_TAGS) + list(candidate_tags)
    with ThreadPoolExecutor(max_workers=16) as pool:
        digests = dict(zip(all_tags, pool.map(tag_digest, all_tags)))
    result = {}
    for ft in FLOATING_TAGS:
        fd = digests[ft]
        if fd is None:
            result[ft] = None
            continue
        result[ft] = next((t for t in candidate_tags if digests[t] == fd), "(no matching version tag)")
    return result


def section_floating(now, candidate_tags, promote_runs):
    print("Floating Docker tags")
    print("====================")
    targets = floating_tag_targets(candidate_tags)
    name_w = max(len(t) for t in FLOATING_TAGS)
    target_w = max((len(v or "(not set)") for v in targets.values()), default=12)
    for ft in FLOATING_TAGS:
        target = targets[ft]
        if target is None:
            print(f"  {ft:<{name_w}}  -> (not set)")
            continue
        r = promote_run_for(promote_runs, ft, target)
        age = f"(promoted {ago(now - parse_ts(r['created_at']))})" if r else "(unknown)"
        print(f"  {ft:<{name_w}}  -> {target:<{target_w}}  {age}")


def section_tags(now, days, tag_dates, classes, main_tags, branch_tags):
    title = f"Tags (last {days} days)" if days > 0 else "Tags (all)"
    print(title)
    print("=" * len(title))
    cutoff = now - timedelta(days=days) if days > 0 else None

    def resolve_branch(tag):
        for branch, tags in branch_tags.items():
            if tag in tags and tag not in main_tags:
                return branch
        return "main" if tag in main_tags else "?"

    rows = []
    for tag, dt in tag_dates.items():
        if not ANY_DATE_TAG_RE.match(tag):
            continue
        if cutoff and dt < cutoff:
            continue
        rows.append((tag, classes.get(tag, "?"), resolve_branch(tag), dt))
    rows.sort(key=lambda r: r[3], reverse=True)
    if not rows:
        print("  (none)")
        return
    tag_w = max(len(r[0]) for r in rows)
    cls_w = max(len(r[1]) for r in rows)
    br_w = max(len(r[2]) for r in rows)
    for tag, cls, branch, dt in rows:
        print(f"  {tag:<{tag_w}}  {cls:<{cls_w}}  {branch:<{br_w}}  {ago(now - dt)}")


def section_branches(now, days, release_branches, tag_dates, classes, main_tags, branch_tags):
    title = "Active release branches"
    print(title)
    print("=" * len(title))
    cutoff = now - timedelta(days=days) if days > 0 else None
    branches = [b for b in release_branches if cutoff is None or b[3] >= cutoff]
    branches.sort(key=lambda b: b[3], reverse=True)
    if not branches:
        print("  (none)")
        return
    name_w = max(len(b[0]) for b in branches)
    for i, (name, sha, author, dt) in enumerate(branches):
        if i > 0:
            print()
        print(f"  {name:<{name_w}}  HEAD {sha}  ({author}, {ago(now - dt)})")
        extras = [t for t in branch_tags.get(name, set()) if t not in main_tags and ANY_DATE_TAG_RE.match(t)]
        rows = [(t, classes.get(t, "?"), tag_dates[t]) for t in extras if t in tag_dates]
        rows.sort(key=lambda r: r[2], reverse=True)
        if not rows:
            print("    (no release tags)")
            continue
        print("    Tags from this branch (not on main):")
        tag_w = max(len(r[0]) for r in rows)
        cls_w = max(len(r[1]) for r in rows)
        for tag, cls, tdt in rows:
            print(f"      {tag:<{tag_w}}  {cls:<{cls_w}}  {ago(now - tdt)}")


def main():
    p = argparse.ArgumentParser(prog="release-status", description="Show current release status.")
    p.add_argument("--days", type=int, default=180, help="time window in days (default 180, 0 = no filter)")
    p.add_argument("--floating", action="store_true", help="only show floating tags section")
    p.add_argument("--no-fetch", action="store_true", help="skip 'git fetch --tags' (default fetches first)")
    args = p.parse_args()

    if not args.no_fetch:
        run(["git", "fetch", "--tags", "--quiet"], check=False)

    now = datetime.now(timezone.utc)

    tag_dates = git_tag_dates()
    cutoff = now - timedelta(days=args.days) if args.days > 0 else None
    candidate_tags = sorted(
        (t for t, dt in tag_dates.items() if VERSION_TAG_RE.match(t) and (cutoff is None or dt >= cutoff)),
        key=lambda t: tag_dates[t],
        reverse=True,
    )

    with ThreadPoolExecutor(max_workers=16) as pool:
        classes_future = pool.submit(fetch_release_classification)
        runs_future = pool.submit(fetch_promote_runs)
        main_future = pool.submit(git_tags_merged_into, "origin/main")

        release_branches = git_release_branches()
        branch_refs = [f"origin/{b[0]}" for b in release_branches]
        branch_tags_list = list(pool.map(git_tags_merged_into, branch_refs))
        branch_tags = dict(zip((b[0] for b in release_branches), branch_tags_list))

        classes = classes_future.result()
        promote_runs = runs_future.result()
        main_tags = main_future.result()

    section_floating(now, candidate_tags, promote_runs)
    if args.floating:
        return
    print()
    section_tags(now, args.days, tag_dates, classes, main_tags, branch_tags)
    print()
    section_branches(now, args.days, release_branches, tag_dates, classes, main_tags, branch_tags)


if __name__ == "__main__":
    main()
