#!/usr/bin/env python3
r"""Parse nextest JUnit XML files and emit markdown reports.

Examples:
    # Render summary to stdout from a directory of per-shard JUnit XMLs:
    scripts/nextest-summary target/nextest

    # Append to GitHub Actions step summary and write a failure-only PR comment:
    scripts/nextest-summary junit-artifacts \
        --title "Nextest (postgres + sqlite)" \
        --pr-comment-out junit-artifacts/pr-comment.md \
        >> "$GITHUB_STEP_SUMMARY"

    # Annotate the failure/flaky tables with main-branch history:
    scripts/nextest-summary junit-artifacts --main-stats main-test-stats.json

    # Quiet everything except warnings:
    scripts/nextest-summary target/nextest --log-level warning
"""

import argparse
import json
import logging
import os
import sys
import xml.etree.ElementTree as ET
from dataclasses import dataclass
from pathlib import Path

log = logging.getLogger("nextest-summary")


@dataclass
class TestCase:
    test_id: str
    status: str
    attempts: int
    time: float


def parse_time(raw: str | None) -> float:
    return float(raw) if raw else 0.0


def derive_status(case: ET.Element) -> str:
    if case.find("failure") is not None or case.find("error") is not None:
        return "failed"
    if case.find("flakyFailure") is not None:
        return "flaky"
    if case.find("skipped") is not None:
        return "skipped"
    return "passed"


def count_attempts(case: ET.Element) -> int:
    prior = sum(1 for child in case if child.tag in ("rerunFailure", "flakyFailure"))
    return prior + 1


def parse_file(path: Path) -> list[TestCase]:
    try:
        tree = ET.parse(path)
    except ET.ParseError as e:
        log.warning("failed to parse %s: %s", path, e)
        return []

    cases: list[TestCase] = []
    for case in tree.iter("testcase"):
        classname = case.attrib.get("classname") or ""
        name = case.attrib.get("name") or ""
        test_id = f"{classname}::{name}"
        cases.append(
            TestCase(
                test_id=test_id,
                status=derive_status(case),
                attempts=count_attempts(case),
                time=parse_time(case.attrib.get("time")),
            )
        )
    return cases


def format_id(test_id: str) -> str:
    return f"`{test_id.replace('`', '')}`"


def load_main_stats(path: Path | None) -> list[dict] | None:
    if path is None:
        return None
    if not path.exists():
        log.warning("main stats file %s not found; skipping history column", path)
        return None
    try:
        data = json.loads(path.read_text())
    except json.JSONDecodeError as e:
        log.warning(
            "failed to parse main stats %s: %s; skipping history column", path, e
        )
        return None
    if not isinstance(data, dict) or not isinstance(data.get("runs"), list):
        log.warning("main stats %s has unexpected shape; skipping history column", path)
        return None
    return data["runs"]


def history_cell(test_id: str, runs: list[dict]) -> str:
    total = len(runs)
    if total == 0:
        return "unknown"
    failed_count = sum(1 for r in runs if test_id in r.get("failed", []))
    flaky_count = sum(1 for r in runs if test_id in r.get("flaky", []))
    if failed_count > 0:
        return f"failed {failed_count}/{total}"
    if flaky_count > 0:
        return f"flaky {flaky_count}/{total}"
    return "passing"


def render_failure_table(cases: list[TestCase], runs: list[dict] | None) -> list[str]:
    if runs is not None:
        lines = [
            "| Test | Attempts | Time (s) | Main history |",
            "|------|----------|----------|--------------|",
        ]
        for c in cases:
            lines.append(
                f"| {format_id(c.test_id)} | {c.attempts} | {c.time:.2f} | {history_cell(c.test_id, runs)} |"
            )
        return lines
    lines = ["| Test | Attempts | Time (s) |", "|------|----------|----------|"]
    for c in cases:
        lines.append(f"| {format_id(c.test_id)} | {c.attempts} | {c.time:.2f} |")
    return lines


def render_slowest_table(cases: list[TestCase]) -> list[str]:
    lines = ["| Test | Time (s) | Status |", "|------|----------|--------|"]
    for c in cases:
        lines.append(f"| {format_id(c.test_id)} | {c.time:.2f} | {c.status} |")
    return lines


def build_summary(title: str, cases: list[TestCase], runs: list[dict] | None) -> str:
    out: list[str] = [f"## {title} test results", ""]

    if not cases:
        out.append("_No JUnit XML files found._")
        return "\n".join(out) + "\n"

    failing = sorted(
        (c for c in cases if c.status == "failed"), key=lambda c: c.test_id
    )
    flaky = sorted((c for c in cases if c.status == "flaky"), key=lambda c: c.test_id)
    non_skipped = [c for c in cases if c.status != "skipped"]
    slowest = sorted(non_skipped, key=lambda c: (-c.time, c.test_id))[:20]

    if failing:
        out.append(f"### Failing tests ({len(failing)})")
        out.append("")
        out.extend(render_failure_table(failing, runs))
        out.append("")

    if flaky:
        out.append(f"### Flaky tests ({len(flaky)})")
        out.append("")
        out.extend(render_failure_table(flaky, runs))
        out.append("")

    out.append("### 20 slowest tests")
    out.append("")
    if slowest:
        out.extend(render_slowest_table(slowest))
    else:
        out.append("_No test cases found._")
    out.append("")

    return "\n".join(out) + "\n"


def build_pr_comment(failing: list[TestCase], runs: list[dict] | None) -> str:
    if not failing:
        return ""
    lines = [f"### Nextest failures ({len(failing)})", ""]
    lines.extend(render_failure_table(failing, runs))
    lines.append("")
    lines.append("See the job step summary for flaky tests and slowest tests.")
    return "\n".join(lines) + "\n"


def main() -> None:
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("junit_dir", type=Path)
    parser.add_argument("--title", default="Nextest")
    parser.add_argument("--pr-comment-out", type=Path)
    parser.add_argument("--main-stats", type=Path)
    parser.add_argument(
        "--log-level",
        default=os.environ.get("NEXTEST_SUMMARY_LOG", "INFO"),
        type=str.upper,
        choices=["DEBUG", "INFO", "WARNING", "ERROR"],
    )
    args = parser.parse_args()

    logging.basicConfig(
        level=args.log_level,
        format="%(levelname)s %(name)s: %(message)s",
        stream=sys.stderr,
    )

    xml_files = sorted(args.junit_dir.rglob("*.xml")) if args.junit_dir.exists() else []
    log.info("parsing %d JUnit file(s) under %s", len(xml_files), args.junit_dir)

    cases: list[TestCase] = []
    for path in xml_files:
        cases.extend(parse_file(path))

    runs = load_main_stats(args.main_stats)

    sys.stdout.write(build_summary(args.title, cases, runs))

    failing = sorted(
        (c for c in cases if c.status == "failed"), key=lambda c: c.test_id
    )

    # The workflow uses hashFiles() on this file to decide whether to delete the
    # sticky PR comment. Skip writing it when there are no failures so the hash
    # is empty and the comment is cleaned up automatically.
    if args.pr_comment_out is not None and failing:
        args.pr_comment_out.write_text(build_pr_comment(failing, runs))


if __name__ == "__main__":
    main()
