#!/bin/sh
set -eu

# Block until the L1 finalized block catches up to the current L1 head.
#
# Espresso reads stake-table events and fee deposits only from finalized L1
# blocks (avoids reorgs). After deploys or validator registrations, those
# transactions are mined but not finalized for ~32 blocks (geth/anvil dev
# mode). Run this gate to ensure downstream consumers see them.
#
# Dependencies: curl, jq.

L1_PROVIDER="${L1_PROVIDER:-http://localhost:${ESPRESSO_L1_PORT:-8545}}"
POLL_INTERVAL="${POLL_INTERVAL:-2}"

rpc() {
  curl -sS -H 'Content-Type: application/json' --data "$1" "$L1_PROVIDER"
}

hex_to_dec() {
  printf '%d' "$1" 2>/dev/null || echo ""
}

get_block() {
  tag="$1"
  resp=$(rpc "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"eth_getBlockByNumber\",\"params\":[\"$tag\",false]}")
  hex=$(echo "$resp" | jq -r '.result.number // empty' 2>/dev/null || echo "")
  [ -n "$hex" ] && hex_to_dec "$hex"
}

target=$(get_block latest)
if [ -z "$target" ]; then
  echo "ERROR: failed to fetch latest L1 block from $L1_PROVIDER" >&2
  exit 1
fi
echo "Waiting for L1 finalized block >= $target (provider=$L1_PROVIDER)"

while :; do
  finalized=$(get_block finalized)
  if [ -n "$finalized" ] && [ "$finalized" -ge "$target" ]; then
    echo "L1 finalized at block $finalized (target $target)"
    exit 0
  fi
  echo "L1 finalized=${finalized:-?} target=$target"
  sleep "$POLL_INTERVAL"
done
