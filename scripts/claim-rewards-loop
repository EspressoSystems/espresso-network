#!/usr/bin/env bash
# Used by process-compose for the local demo only.
set -euo pipefail

SLEEP_INTERVAL="${1:-10}"

echo "Starting reward claiming loop (checking every ${SLEEP_INTERVAL}s)..."

while true; do
  unclaimed=$(staking-cli --no-config unclaimed-rewards)
  if [ "$unclaimed" != "0 ESP" ]; then
    echo "Claiming $unclaimed..."
    staking-cli --no-config claim-rewards
    echo "Successfully claimed rewards"
  else
    echo "No rewards to claim yet ($unclaimed)"
  fi
  sleep "$SLEEP_INTERVAL"
done
