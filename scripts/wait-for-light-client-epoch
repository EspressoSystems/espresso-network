#!/usr/bin/env bash
set -euo pipefail

# Wait for the LightClient proxy to report currentEpoch() >= TARGET_EPOCH.
# Uses curl + jq (not cast) so it works in CI environments without foundry.
#
# Function selector: keccak256("currentEpoch()")[:4] = 0x76671808
# Return is a uint64 padded to 32 bytes.

TARGET_EPOCH="${1:-1}"
LC_ADDR="${ESPRESSO_LIGHT_CLIENT_PROXY_ADDRESS:?ESPRESSO_LIGHT_CLIENT_PROXY_ADDRESS not set}"
L1_PROVIDER="${L1_PROVIDER:?L1_PROVIDER not set}"
POLL_INTERVAL="${POLL_INTERVAL:-5}"
SELECTOR="0x76671808"

echo "Waiting for LightClient ${LC_ADDR} currentEpoch() >= ${TARGET_EPOCH} via ${L1_PROVIDER}"
while true; do
    response=$(curl -s -X POST "$L1_PROVIDER" \
        -H 'Content-Type: application/json' \
        -d "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"eth_call\",\"params\":[{\"to\":\"${LC_ADDR}\",\"data\":\"${SELECTOR}\"},\"latest\"]}" \
        || true)
    hex_result=$(echo "$response" | jq -r '.result // empty' 2>/dev/null || true)
    if [[ "$hex_result" =~ ^0x[0-9a-fA-F]+$ ]] && [ "$hex_result" != "0x" ]; then
        epoch=$((hex_result))
        if (( epoch >= TARGET_EPOCH )); then
            echo "LightClient reached epoch ${epoch}"
            exit 0
        fi
        echo "LightClient epoch=${epoch} (waiting for >= ${TARGET_EPOCH}), sleeping ${POLL_INTERVAL}s"
    else
        err=$(echo "$response" | jq -r '.error.message // "no result"' 2>/dev/null || echo "no response")
        echo "LightClient call failed: ${err} (waiting for >= ${TARGET_EPOCH}), sleeping ${POLL_INTERVAL}s"
    fi
    sleep "$POLL_INTERVAL"
done
